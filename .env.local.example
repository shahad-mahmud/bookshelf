# Supabase — pooled (Transaction-mode) for runtime
DATABASE_URL=postgres://postgres:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Supabase — direct connection for migrations
DIRECT_URL=postgres://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
# Supabase SDK
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Resend (transactional email — invite links)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@mail.yourdomain.com

# Optional
DEFAULT_CURRENCY=BDT
# Optional: public site URL (required in production for Server Actions CSRF check)
NEXT_PUBLIC_SITE_URL=https://bookshelf.example.com
# Optional: comma-separated extra origins for Server Actions (e.g. Vercel previews)
ADDITIONAL_ALLOWED_ORIGINS=bookshelf-git-main.vercel.app,bookshelf-abc123.vercel.app
